# ---------------------------------------------------------------------------
# Agent5G — backend environment variables
# Copy this file to .env and edit. The .env file is git-ignored (never commit it).
# ---------------------------------------------------------------------------

# Runtime environment
ENV=dev                              # dev | test | demo

# Database (SQLite — path relative to the backend/ directory)
DB_PATH=data/agent5g.db

# CORS — frontend origin (default: local Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# LLM — default is REPLAY (offline, $0, no key needed)
# For live reasoning use a FREE-TIER provider only (CST-1):
#   anthropic  → Claude free credits  (model: claude-4.8)
#   gemini     → Google AI Studio free tier  (model: gemini-1.5-flash)
#   groq       → Groq free tier  (model: llama-3.1-8b-instant)
#   openrouter → OpenRouter free models
#   ollama     → fully local, no key, $0  (model: llama3)
# ---------------------------------------------------------------------------
LLM__MODE=replay                     # replay (default/$0) | record | live
LLM__PROVIDER=anthropic              # anthropic | gemini | groq | openrouter | ollama
LLM__MODEL=claude-4.8                # model name for the chosen provider
LLM__API_KEY=                        # free-tier key; leave blank for replay or ollama
LLM__BASE_URL=                       # OpenAI-compatible base URL (groq/openrouter/ollama)
LLM__FIXTURES_DIR=tests/fixtures/llm # where replay fixtures are stored

# ---------------------------------------------------------------------------
# Simulation
# ---------------------------------------------------------------------------
SIM__DEFAULT_SEED=42                 # RNG seed — change for different deterministic runs
SIM__TICK_MS=1000                    # simulation tick interval in milliseconds
SIM__DEFAULT_SCENARIO=baseline_healthy

# Logging
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
